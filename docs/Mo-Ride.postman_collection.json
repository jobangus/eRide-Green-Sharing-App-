{
  "info": {
    "_postman_id": "moride-collection-v1",
    "name": "Mo-Ride API",
    "description": "Complete API test collection for Mo-Ride (Monash Ride Sharing App). \n\nSetup:\n1. Start services with `make dev`\n2. The collection uses environment variables — set the `base_url` variable to `http://localhost:8000`\n3. Run the Auth/Login request first to auto-populate `access_token`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "ride_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "Auth Service Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:5001/health"
          }
        },
        {
          "name": "Ride Matching Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:5002/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@monash.edu\",\n  \"password\": \"TestPass123\",\n  \"name\": \"Test User\",\n  \"role\": \"rider\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.otp) pm.collectionVariables.set('otp', json.otp);",
                  "if (json.user_id) pm.collectionVariables.set('user_id', json.user_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — Non-Monash (should fail)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"TestPass123\",\n  \"name\": \"Test\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects non-Monash email (400)', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Error is invalid_email', () => pm.expect(json.error).to.eql('invalid_email'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@monash.edu\",\n  \"otp\": \"{{otp}}\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carol.rider@monash.edu\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "pm.test('Has access token', () => pm.expect(json.access_token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Driver (Alice)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.driver@monash.edu\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('driver_access_token', json.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has email', () => pm.expect(json.email).to.include('@monash.edu'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carol Johnson Updated\",\n  \"phone\": \"+61411222333\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Driver",
      "item": [
        {
          "name": "Go Online",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/driver/go-online",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driver_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lat\": -37.9105,\n  \"lng\": 145.1362\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is online', () => pm.expect(json.status).to.eql('online'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Driver Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/driver/status",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_access_token}}" }]
          }
        },
        {
          "name": "Go Offline",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/driver/go-offline",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Rides",
      "item": [
        {
          "name": "Estimate Fare",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/rides/estimate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_lat\": -37.9105,\n  \"pickup_lng\": 145.1362,\n  \"dropoff_lat\": -37.8777,\n  \"dropoff_lng\": 145.0452\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has fare', () => pm.expect(json.fare.final_fare).to.be.above(0));",
                  "pm.test('Has distance', () => pm.expect(json.distance_km).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "Request Ride",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/rides/request",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup_lat\": -37.9105,\n  \"pickup_lng\": 145.1362,\n  \"pickup_address\": \"Monash Clayton Campus\",\n  \"dropoff_lat\": -37.8777,\n  \"dropoff_lng\": 145.0452,\n  \"dropoff_address\": \"Monash Caulfield Campus\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202', () => pm.response.to.have.status(202));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('ride_id', json.ride_id);",
                  "pm.test('Status is matching', () => pm.expect(json.status).to.eql('matching'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Ride",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/rides/{{ride_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Cancel Ride",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/rides/{{ride_id}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Change of plans\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Sustainability",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/sustainability/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has co2 field', () => pm.expect(json.total_co2_saved_kg).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Rides List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/sustainability/rides",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/payments/create-intent",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ride_id\": \"{{ride_id}}\"\n}"
            }
          }
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/payments/status/{{ride_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    }
  ]
}
