{
  "expo": {
    "name": "Mo-Ride",
    "slug": "moride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "edu.monash.moride",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Mo-Ride needs your location to match you with drivers and show your ride on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Mo-Ride uses your location to track rides in progress."
      }
    },
    "android": {
      "package": "edu.monash.moride",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Mo-Ride needs location to match you with nearby drivers."
        }
      ]
    ],
    "scheme": "moride",
    "extra": {
      "API_BASE_URL": "http://localhost:8000",
      "eas": {
        "projectId": "moride-local-dev"
      }
    }
  }
}
