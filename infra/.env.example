# ============================================================
# Mo-Ride Environment Configuration
# Copy this file to .env in the project root and fill in values.
# NEVER commit .env to version control.
# ============================================================

# --- Postgres ---
POSTGRES_PASSWORD=moride_secret_change_me

# --- Redis ---
REDIS_PASSWORD=redis_secret_change_me

# --- JWT ---
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# --- Google Maps ---
# Get from https://console.cloud.google.com/ (Distance Matrix + Directions + Places APIs)
# Leave blank to use stub fallback (assumes straight-line distance)
GOOGLE_MAPS_API_KEY=

# --- Stripe ---
# Use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_TEST_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# --- MinIO (S3-compatible local storage) ---
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key_change_me
MINIO_BUCKET_PROFILES=moride-profiles

# --- Email (local dev = Mailhog, prod = SES/SendGrid) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@moride.monash.edu
# For production (e.g. SES):
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your_ses_smtp_user
# SMTP_PASS=your_ses_smtp_pass
# SMTP_TLS=true

# --- Fare Config ---
BASE_RATE=2.00
RATE_PER_KM=1.50
PEAK_HOURS_MORNING_START=07:00
PEAK_HOURS_MORNING_END=09:00
PEAK_HOURS_EVENING_START=16:00
PEAK_HOURS_EVENING_END=19:00
PEAK_MULTIPLIER=1.2

# --- CO2 Config (kg CO2 per km baselines) ---
# Average petrol car: ~0.21 kg CO2/km
CO2_PER_KM_PETROL=0.21
# MoRide shared ride: ~0.09 kg CO2/km per passenger (car split by passengers)
CO2_PER_KM_SHARED=0.09

# --- Driver Matching ---
DRIVER_SEARCH_RADIUS_KM=5
DRIVER_ACCEPT_TIMEOUT_SECONDS=30

# --- Ports (used by nginx upstream; override if needed) ---
AUTH_SERVICE_PORT=5001
RIDE_MATCHING_SERVICE_PORT=5002
LOCATION_TRACKING_SERVICE_PORT=5003
PAYMENTS_SERVICE_PORT=5004
